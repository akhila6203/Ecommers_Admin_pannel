{
  "name": "lm-shopping-mall-backend",
  "version": "1.0.0",
  "description": "LM Shopping Mall - Production Ready Ecommerce Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
